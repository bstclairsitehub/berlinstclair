# Database (Vercel Postgres or standard PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js v5 - generate with: npx auth secret
AUTH_SECRET="generate-with-npx-auth-secret"

# GitHub OAuth (create at https://github.com/settings/apps)
AUTH_GITHUB_ID="your-github-oauth-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-client-secret"

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# App URL (set to your Vercel URL or custom domain)
NEXTAUTH_URL="https://the-daily-gay.vercel.app"
